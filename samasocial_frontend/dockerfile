# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files first (layer cache)
COPY package.json package-lock.json ./

# Install deps
RUN npm ci

# Copy source
COPY . .

# Build — passes env var at build time
ARG VITE_API_BASE_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm run build

# Stage 2: Serve with nginx
# WHY nginx NOT node:
# nginx serves static files 10x faster
# No runtime dependencies
# ~20MB final image vs ~200MB node
FROM nginx:alpine

# Copy built files
COPY --from=builder /app/dist /usr/share/nginx/html

# WHY CUSTOM nginx config:
# React Router needs all routes to return index.html
# Default nginx returns 404 on /quiz, /session etc
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]